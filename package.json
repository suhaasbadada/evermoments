{
  "name": "evermoments-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,green \"npm run dev:web\" \". .venv/bin/activate && npm run dev:api\"",
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "lint:web": "npm --prefix apps/web run lint",
    "dev:api": "python -m uvicorn app.main:app --reload --app-dir apps/api --env-file apps/api/.env",
    "dev:docker": "docker compose up --build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
