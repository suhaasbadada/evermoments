# Committed template for apps/api. Copy to apps/api/.env for local dev:
#     cp apps/api/.env.example apps/api/.env
# `npm run dev:api` passes --env-file apps/api/.env, so the .env file must exist.
# The API boots with these defaults as-is (offline, no cognee, no keys).

APP_NAME=evermoments-api
APP_ENV=development
DATABASE_URL=sqlite:///./evermoments.db
FRONTEND_ORIGIN=http://localhost:3000
CORS_ORIGINS=

# --- Cognee Memory Engine (Module 3) ---
MEMORY_BACKEND=local          # local | blob | graph  (local = offline, no cognee)
CONTRADICTION_WINDOW_MIN=180  # double-dose look-back window (minutes)

# Graph backend (MEMORY_BACKEND=graph) storage mode:
#   local = cognee embedded on this machine (default, offline for graph/vector)
#   cloud = route graph/vector ops to Cognee Cloud (adds network latency)
COGNEE_MODE=local
# Required ONLY for COGNEE_MODE=cloud. If either is blank, the graph backend logs a
# warning and falls back to the local/embedded path (never silently "cloud").
COGNEE_CLOUD_URL=
COGNEE_API_KEY=
# Cognee graph recall/indexing requires an OpenAI-compatible key.
# GROQ_API_KEY is only for optional final answer synthesis (MEMORY_USE_GROQ_SYNTHESIS).
# Set either COGNEE_LLM_API_KEY or OPENAI_API_KEY; COGNEE_LLM_API_KEY takes precedence.
COGNEE_LLM_MODEL=gpt-4o-mini
COGNEE_LLM_API_KEY=
OPENAI_API_KEY=
